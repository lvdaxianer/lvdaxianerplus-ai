{
  "baseUrl": "https://api.example.com",
  "auth": {
    "type": "bearer",
    "default": "default-token-key"
  },
  "tools": {
    "addAge": {
      "description": "添加用户年龄",
      "method": "POST",
      "path": "/api/users/{userId}/age",
      "body": {
        "age": "number"
      }
    },
    "getUser": {
      "description": "根据ID获取用户信息",
      "method": "GET",
      "path": "/api/users/{userId}"
    },
    "queryUser": {
      "description": "根据用户名查询用户",
      "method": "GET",
      "path": "/api/users",
      "queryParams": {
        "name": "string"
      }
    }
  },
  "sqlite": {
    "enabled": true,
    "dbPath": "./data/test-final-toast-check1.db",
    "maxDays": 30,
    "batchSize": 100,
    "syncInterval": 60000
  },
  "circuitBreaker": {
    "enabled": true,
    "failureThreshold": 5,
    "successThreshold": 2,
    "halfOpenTime": 30000
  },
  "cache": {
    "enabled": true,
    "ttl": 90000,
    "maxSize": 1000
  },
  "timeout": {
    "connect": 5000,
    "read": 30000,
    "write": 30000
  },
  "retry": {
    "enabled": false,
    "maxAttempts": 3,
    "delay": 1000,
    "backoff": 2,
    "retryOn": [
      429,
      500,
      502,
      503,
      504
    ]
  },
  "logging": {
    "level": "info",
    "logRequest": true,
    "logResponse": true,
    "logHeaders": false,
    "sensitiveHeaders": [
      "authorization",
      "x-api-key"
    ],
    "file": {
      "enabled": false,
      "dir": "./logs",
      "maxSize": 300,
      "rotateByMonth": true,
      "logRequestBody": true,
      "logResponseBody": true,
      "logRequestHeaders": true,
      "logResponseHeaders": true
    }
  },
  "metrics": {
    "enabled": true,
    "port": 11112
  },
  "healthCheck": {
    "enabled": true,
    "port": 11112
  },
  "server": {
    "transport": "stdio",
    "ssePort": 11113,
    "httpPort": 11112
  },
  "compression": {
    "enabled": false,
    "threshold": 1024,
    "level": 6,
    "mimeTypes": [
      "application/json",
      "text/plain",
      "text/html"
    ]
  },
  "hotReload": {
    "enabled": true,
    "watchFile": true,
    "debounceMs": 1000
  },
  "backup": {
    "enabled": true,
    "dir": "./backups",
    "maxVersions": 10,
    "schedule": "0 * * * *"
  },
  "alert": {
    "enabled": false,
    "logDir": "./logs",
    "channels": [],
    "rules": [
      {
        "type": "circuitBreaker",
        "enabled": true,
        "cooldown": 60000,
        "severity": "critical"
      },
      {
        "type": "rateLimit",
        "enabled": true,
        "threshold": 100,
        "cooldown": 30000,
        "severity": "warning"
      },
      {
        "type": "concurrency",
        "enabled": true,
        "threshold": 50,
        "cooldown": 30000,
        "severity": "warning"
      },
      {
        "type": "errorRate",
        "enabled": true,
        "threshold": 10,
        "cooldown": 60000,
        "severity": "critical"
      },
      {
        "type": "timeout",
        "enabled": true,
        "threshold": 5,
        "cooldown": 30000,
        "severity": "warning"
      }
    ],
    "templates": {
      "circuitBreaker": "🔴 熔断器告警：{tool} 状态变更 {state}，连续失败 {failures} 次",
      "rateLimit": "⚠️ 限流告警：{tool} 请求被拒绝，剩余令牌 {remaining}",
      "concurrency": "⚠️ 并发告警：活跃请求 {active}/{max}，队列长度 {queue}",
      "errorRate": "🔴 错误率告警：{tool} 错误率 {rate}%，超过阈值 {threshold}%",
      "timeout": "⚠️ 超时告警：{tool} 请求超时，耗时 {duration}ms"
    },
    "historyRetention": 30,
    "maxAlertsPerHour": 10
  },
  "audit": {
    "enabled": true,
    "maskSensitiveFields": true
  }
}