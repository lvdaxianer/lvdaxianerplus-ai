<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MCP Gateway Dashboard</title>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <!-- Ace Editor CDN -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.32.6/ace.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.32.6/mode-json.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/ace/1.32.6/ext-language_tools.min.js"></script>
  <style>
    <%- css %>
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <header class="header">
      <div style="display:flex;align-items:center;gap:8px;">
        <h1>MCP Gateway</h1>
        <span class="port-badge" style="background:var(--success);color:white;padding:4px 10px;border-radius:12px;font-size:12px;font-weight:600;">
          端口: <%= data.serverPort %>
        </span>
        <!-- 端口查询命令提示 -->
        <div class="port-query-command" style="display:flex;align-items:center;gap:6px;background:#F1F5F9;padding:4px 10px;border-radius:8px;border:1px solid var(--border);cursor:pointer;" onclick="copyPortQueryCommand()" title="点击复制端口查询命令">
          <svg style="width:14px;height:14px;color:var(--text-muted);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
          <code style="font-size:11px;color:var(--text-muted);font-family:monospace;">lsof -i :<%= data.serverPort %></code>
          <span class="copy-hint" style="font-size:10px;color:var(--text-muted);opacity:0;transition:opacity 0.2s;">已复制!</span>
        </div>
      </div>
      <nav class="header-nav">
        <button class="nav-btn active" data-page="overview">总览</button>
        <button class="nav-btn" data-page="tools">工具管理</button>
        <button class="nav-btn" data-page="logs">日志详情</button>
        <button class="nav-btn" data-page="stats">统计分析</button>
        <button class="nav-btn" data-page="alerts">告警管理</button>
        <button class="nav-btn" data-page="config">配置编辑</button>
      </nav>
      <div style="display:flex;align-items:center;gap:12px;">
        <select id="refresh-interval" style="padding:6px 12px;border-radius:6px;border:1px solid var(--border);font-size:13px;">
          <option value="5">5秒</option>
          <option value="10" selected>10秒</option>
          <option value="15">15秒</option>
          <option value="30">30秒</option>
          <option value="60">60秒</option>
          <option value="0">关闭自动刷新</option>
        </select>
        <button class="btn" id="refresh-btn" style="background:var(--primary);color:white;border-color:var(--primary);padding:6px 12px;border-radius:6px;font-size:13px;">
          <svg style="width:16px;height:16px;margin-right:4px;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          刷新
        </button>
      </div>
    </header>

    <!-- Overview Page -->
    <%- include('partials/overview-page', { data: data }) %>

    <!-- Tools Page -->
    <%- include('partials/tools-page') %>

    <!-- Logs Page -->
    <%- include('partials/logs-page') %>

    <!-- Stats Page -->
    <%- include('partials/stats-page') %>

    <!-- Alerts Page -->
    <%- include('partials/alerts-page') %>

    <!-- Config Page -->
    <%- include('partials/config-page') %>

    <!-- Modals -->
    <%- include('partials/modals') %>

    <!-- Toast Container -->
    <div id="toast-container" class="toast-container"></div>

    <!-- JavaScript -->
    <%- include('partials/scripts', { serverPort: data.serverPort }) %>
  </div>
</body>
</html>